{
  "manifest_version": 3,
  "name": "G-Account Switcher",
  "version": "2.0.0",
  "description": "Set your default Google account across all Google services. Rewrite /u/X/ and authuser= in URLs automatically.",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.youtube.com/*",
    "*://*.googleapis.com/*",
    "*://gmail.com/*",
    "*://*.gmail.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "32": "src/icons/icon32.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  }
}
